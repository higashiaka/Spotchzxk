{
    "projectName": "Streamer Stock Exchange (SSE) - CHZZK Dedicated",
    "techStack": {
        "backend": "Java / Spring Boot",
        "orm": "Spring Data JPA (Hibernate)",
        "frontend": "TypeScript",
        "database": "MySQL or PostgreSQL"
    },
    "systemArchitecture": {
        "marketDesign": {
            "initialListingPrice": 1000,
            "currencyUnit": "Coin",
            "valuationMetrics": {
                "excluded": [
                    "realtimeViewerCount"
                ],
                "included": [
                    "followerCount",
                    "cumulativeBroadcastHours"
                ]
            },
            "valueScoreFormula": {
                "formula": "VS = (Normalized_Followers * 0.6) + (Normalized_Broadcast_Hours * 0.4)",
                "weights": {
                    "followerCount": 0.6,
                    "cumulativeBroadcastHours": 0.4
                }
            },
            "supplyPolicy": {
                "type": "Inversely Proportional to Value Score (VS)",
                "strategy": {
                    "highVsStreamers": {
                        "tier": "Premium / Blue-chip Stock",
                        "supply": "Low (High Scarcity)",
                        "marketEffect": "Drives immediate price surges upon listing due to low availability."
                    },
                    "lowVsStreamers": {
                        "tier": "Growth / Penny Stock",
                        "supply": "High (High Liquidity)",
                        "marketEffect": "Affordable entry point with scalable growth potential."
                    }
                }
            }
        },
        "automatedDividendSystem": {
            "triggerCondition": {
                "chzzkApiField": "liveStatus",
                "activeValue": "OPEN"
            },
            "schedulerInterval": "Every 10 minutes via @Scheduled cron",
            "payoutMechanism": "Fully automated background bulk credit (No user action or pop-up required)",
            "dividendFormulas": {
                "totalPoolPerSlot": "Base_Dividend_Unit * Broadcast_Hours_Weight",
                "userPayout": "Total_Pool_per_Slot * (User_Owned_Shares / Total_Issued_Supply)"
            }
        },
        "listingAutomationPipeline": {
            "input": "CHZZK Channel URL (parsed to extract channelId via RegEx)",
            "steps": [
                "Parse unique 'channelId' string from URL.",
                "Call CHZZK OpenAPI to fetch channel metadata (streamerName, profileImageUrl, followerCount).",
                "Validate against Minimum Listing Threshold (e.g., 500 followers).",
                "Calculate Value Score (VS) and determine totalSupply.",
                "Persist into Database via JPA StockRepository (channelId as assigned Id)."
            ]
        }
    },
    "jpaEntityAndTypeScriptTypes": {
        "entities": {
            "Stock": {
                "description": "Maps to 'stocks' table. channelId is manually assigned as @Id without GenerationType.",
                "fields": [
                    {
                        "name": "channelId",
                        "jpaType": "String",
                        "tsType": "string",
                        "annotations": [
                            "@Id",
                            "@Column(length = 50)"
                        ],
                        "desc": "Unique CHZZK channel hash string"
                    },
                    {
                        "name": "streamerName",
                        "jpaType": "String",
                        "tsType": "string",
                        "annotations": [
                            "@Column(nullable = false, length = 100)"
                        ],
                        "desc": "Streamer nickname from CHZZK"
                    },
                    {
                        "name": "profileImageUrl",
                        "jpaType": "String",
                        "tsType": "string",
                        "annotations": [
                            "@Column(columnDefinition = \"TEXT\")"
                        ],
                        "desc": "Profile image URL"
                    },
                    {
                        "name": "followerCount",
                        "jpaType": "int",
                        "tsType": "number",
                        "annotations": [
                            "@Column"
                        ],
                        "desc": "Total followers at synchronization point"
                    },
                    {
                        "name": "baseBroadcastHours",
                        "jpaType": "int",
                        "tsType": "number",
                        "annotations": [
                            "@Column"
                        ],
                        "desc": "Historical broadcast metric / VOD count"
                    },
                    {
                        "name": "totalSupply",
                        "jpaType": "long",
                        "tsType": "number",
                        "annotations": [
                            "@Column(nullable = false)"
                        ],
                        "desc": "Total issued stock volume"
                    },
                    {
                        "name": "currentPrice",
                        "jpaType": "int",
                        "tsType": "number",
                        "annotations": [
                            "@Column"
                        ],
                        "desc": "Current market trading price (Starts at 1000)"
                    },
                    {
                        "name": "isLive",
                        "jpaType": "boolean",
                        "tsType": "boolean",
                        "annotations": [
                            "@Column"
                        ],
                        "desc": "Real-time live streaming status"
                    },
                    {
                        "name": "createdAt",
                        "jpaType": "LocalDateTime",
                        "tsType": "string",
                        "annotations": [
                            "@Column(updatable = false)"
                        ],
                        "desc": "Timestamp of listing"
                    }
                ]
            },
            "UserShare": {
                "description": "Maps to 'user_shares' table. Represents N:M relationship mapping between User and Stock.",
                "fields": [
                    {
                        "name": "shareId",
                        "jpaType": "Long",
                        "tsType": "number",
                        "annotations": [
                            "@Id",
                            "@GeneratedValue(strategy = GenerationType.IDENTITY)"
                        ],
                        "desc": "Surrogate primary key"
                    },
                    {
                        "name": "user",
                        "jpaType": "User",
                        "tsType": "any",
                        "annotations": [
                            "@ManyToOne(fetch = FetchType.LAZY)",
                            "@JoinColumn(name = \"user_id\")"
                        ],
                        "desc": "Associated User entity"
                    },
                    {
                        "name": "stock",
                        "jpaType": "Stock",
                        "tsType": "Stock",
                        "annotations": [
                            "@ManyToOne(fetch = FetchType.LAZY)",
                            "@JoinColumn(name = \"channel_id\")"
                        ],
                        "desc": "Associated Stock entity (FK mapping to channel_id)"
                    },
                    {
                        "name": "quantity",
                        "jpaType": "long",
                        "tsType": "number",
                        "annotations": [
                            "@Column"
                        ],
                        "desc": "Volume of shares held by user"
                    },
                    {
                        "name": "updatedAt",
                        "jpaType": "LocalDateTime",
                        "tsType": "string",
                        "annotations": [
                            "@Column"
                        ],
                        "desc": "Last modified timestamp"
                    }
                ]
            },
            "DividendLog": {
                "description": "Maps to 'dividend_logs' table. Stores history of batch dividend operations.",
                "fields": [
                    {
                        "name": "logId",
                        "jpaType": "Long",
                        "tsType": "number",
                        "annotations": [
                            "@Id",
                            "@GeneratedValue(strategy = GenerationType.IDENTITY)"
                        ],
                        "desc": "Unique log identifier"
                    },
                    {
                        "name": "stock",
                        "jpaType": "Stock",
                        "tsType": "Stock",
                        "annotations": [
                            "@ManyToOne(fetch = FetchType.LAZY)",
                            "@JoinColumn(name = \"channel_id\")"
                        ],
                        "desc": "Stock entity that triggered the dividend"
                    },
                    {
                        "name": "totalDividendPool",
                        "jpaType": "int",
                        "tsType": "number",
                        "annotations": [
                            "@Column(nullable = false)"
                        ],
                        "desc": "Total coins distributed in this batch"
                    },
                    {
                        "name": "payoutReason",
                        "jpaType": "String",
                        "tsType": "string",
                        "annotations": [
                            "@Column"
                        ],
                        "desc": "Context logs (e.g., '10-min batch live dividend')"
                    },
                    {
                        "name": "createdAt",
                        "jpaType": "LocalDateTime",
                        "tsType": "string",
                        "annotations": [
                            "@Column"
                        ],
                        "desc": "Execution timestamp"
                    }
                ]
            }
        }
    },
    "springDevelopmentNotes": {
        "scheduling": "Implement @Scheduled(cron = '0 */10 * * * *') in a @Component class paired with @EnableScheduling on the application main class.",
        "performanceOptimization": "Avoid transactional N+1 dirty checking for batch dividend logic. Utilize @Modifying with native queries or JPQL in UserShareRepository to execute bulk updates directly on the DB server.",
        "bulkQueryExample": "UPDATE users u JOIN user_shares s ON u.id = s.user_id SET u.coin_balance = u.coin_balance + (s.quantity * :calculatedRate) WHERE s.channel_id = :activeChannelId"
    }
}